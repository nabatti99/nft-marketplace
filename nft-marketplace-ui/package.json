    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "globals": "^15.9.0",
    "i18next": "^23.15.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.8.0",
    "react-i18next": "^15.0.2",
    "storybook": "^8.3.4",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  },
  "packageManager": "yarn@4.12.0"
